{
  "permissions": {
    "allow": [
      "Bash(gh run:*)",
      "Bash(gh release:*)",
      "Bash(mkdir -p icon.iconset)",
      "Bash(sips -z 16 16 icon.png --out icon.iconset/icon_16x16.png)",
      "Bash(sips -z 32 32 icon.png --out icon.iconset/icon_16x16@2x.png)",
      "Bash(sips -z 32 32 icon.png --out icon.iconset/icon_32x32.png)",
      "Bash(sips -z 64 64 icon.png --out icon.iconset/icon_32x32@2x.png)",
      "Bash(sips -z 128 128 icon.png --out icon.iconset/icon_128x128.png)",
      "Bash(sips -z 256 256 icon.png --out icon.iconset/icon_128x128@2x.png)",
      "Bash(sips -z 256 256 icon.png --out icon.iconset/icon_256x256.png)",
      "Bash(sips -z 512 512 icon.png --out icon.iconset/icon_256x256@2x.png)",
      "Bash(sips -z 512 512 icon.png --out icon.iconset/icon_512x512.png)",
      "Bash(cp icon.png icon.iconset/icon_512x512@2x.png)",
      "Bash(iconutil -c icns icon.iconset -o icon.icns)",
      "Bash(rm -rf icon.iconset)"
    ]
  }
}
