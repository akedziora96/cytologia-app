{
  "$schema": "https://raw.githubusercontent.com/nicholasxjy/tauri-docs/refs/heads/v2/references/.schema/config.schema.json",
  "productName": "Cytologia",
  "version": "1.0.0",
  "identifier": "com.cytologia.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.png"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Cytologia — Wyniki Badań",
        "width": 1100,
        "height": 750,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:cytologia.db"]
    }
  }
}
